<%@ Page Title="About" Language="C#" MasterPageFile="~/Site.Master" AutoEventWireup="true" CodeBehind="About.aspx.cs" Inherits="Project_2_ServiceWebsite.About" %>

<asp:Content ID="BodyContent" ContentPlaceHolderID="MainContent" runat="server">

    <section class="section">
        <div class="container">
            <h2 class="section-title">About EasyService</h2>

            <div class="about-layout">
                <div class="about-image">
                    <img src="Images/about-team-new.jpg" alt="EasyService Team" />
                </div>

                <div class="about-box">
                    <h3>Who We Are</h3>
                    <p>
                        EasyService is a professional home service company that provides fast,
                        affordable, and reliable maintenance solutions for modern homes.
                    </p>

                    <h3>Our Mission</h3>
                    <p>
                        Our mission is to make home services simple, accessible, and stress-free
                        for every customer by offering trusted staff, clear pricing, and quality work.
                    </p>

                    <h3>What We Offer</h3>
                    <p>
                        We provide plumbing, electrical repair, cleaning, painting, air conditioner service,
                        and furniture assembly with customer-focused support and professional results.
                    </p>

                    <h3>Why Customers Choose Us</h3>
                    <p>
                        Customers choose EasyService because we deliver on time, communicate clearly,
                        and always focus on safety, convenience, and satisfaction.
                    </p>
                </div>
            </div>
        </div>
    </section>

</asp:Content>